<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VR Sync Controller</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Cairo:wght@300;400;700&display=swap');

  :root {
    --bg: #050810;
    --surface: #0d1117;
    --accent: #00f5ff;
    --accent2: #ff006e;
    --accent3: #7b2fff;
    --text: #e8eaf6;
    --muted: #4a5568;
    --glow: 0 0 20px rgba(0,245,255,0.4);
    --glow2: 0 0 20px rgba(255,0,110,0.4);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,245,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,245,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  /* HEADER */
  header {
    text-align: center;
    margin-bottom: 50px;
  }

  .logo {
    font-family: 'Orbitron', monospace;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 900;
    letter-spacing: 4px;
    background: linear-gradient(135deg, var(--accent), var(--accent3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: none;
    filter: drop-shadow(0 0 20px rgba(0,245,255,0.5));
  }

  .subtitle {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* STATUS BAR */
  .status-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    background: var(--surface);
    border: 1px solid rgba(0,245,255,0.15);
    border-radius: 16px;
    padding: 20px 30px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    font-family: 'Orbitron', monospace;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    text-shadow: var(--glow);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
  }

  .divider { width: 1px; height: 50px; background: rgba(255,255,255,0.08); }

  /* CONNECTION STATUS */
  .conn-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
  }

  .dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse-dot 1.5s infinite;
  }

  .dot.waiting { background: var(--accent2); animation: pulse-dot2 1.5s infinite; }

  @keyframes pulse-dot {
    0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.6); }
    50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
  }
  @keyframes pulse-dot2 {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,0,110,0.6); }
    50% { box-shadow: 0 0 0 6px rgba(255,0,110,0); }
  }

  /* MAIN CONTROLS */
  .controls-card {
    background: var(--surface);
    border: 1px solid rgba(0,245,255,0.1);
    border-radius: 24px;
    padding: 40px;
    margin-bottom: 30px;
    text-align: center;
  }

  .role-badge {
    display: inline-block;
    padding: 6px 18px;
    border-radius: 100px;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 30px;
    font-weight: 700;
  }

  .role-badge.host {
    background: rgba(0,245,255,0.1);
    border: 1px solid rgba(0,245,255,0.3);
    color: var(--accent);
  }

  .role-badge.viewer {
    background: rgba(123,47,255,0.1);
    border: 1px solid rgba(123,47,255,0.3);
    color: var(--accent3);
  }

  /* BIG PLAY BUTTON */
  .play-btn {
    width: 140px; height: 140px;
    border-radius: 50%;
    border: 3px solid var(--accent);
    background: rgba(0,245,255,0.05);
    color: var(--accent);
    font-size: 3rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 30px;
    transition: all 0.3s ease;
    position: relative;
    box-shadow: var(--glow), inset 0 0 30px rgba(0,245,255,0.05);
  }

  .play-btn::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(0,245,255,0.2);
    animation: rotate-ring 4s linear infinite;
  }

  @keyframes rotate-ring {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .play-btn:hover {
    background: rgba(0,245,255,0.15);
    box-shadow: 0 0 40px rgba(0,245,255,0.6), inset 0 0 40px rgba(0,245,255,0.1);
    transform: scale(1.05);
  }

  .play-btn:disabled {
    border-color: var(--muted);
    color: var(--muted);
    cursor: not-allowed;
    box-shadow: none;
  }

  .play-btn.playing {
    border-color: var(--accent2);
    color: var(--accent2);
    box-shadow: var(--glow2), inset 0 0 30px rgba(255,0,110,0.05);
  }

  .play-btn.playing::before { border-color: rgba(255,0,110,0.2); }

  /* ACTION BUTTONS */
  .btn-row {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  .btn {
    padding: 12px 28px;
    border-radius: 12px;
    border: 1px solid;
    font-family: 'Cairo', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex; align-items: center; gap: 8px;
  }

  .btn-cyan {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0,245,255,0.05);
  }
  .btn-cyan:hover { background: rgba(0,245,255,0.15); box-shadow: var(--glow); }

  .btn-red {
    border-color: var(--accent2);
    color: var(--accent2);
    background: rgba(255,0,110,0.05);
  }
  .btn-red:hover { background: rgba(255,0,110,0.15); box-shadow: var(--glow2); }

  .btn-purple {
    border-color: var(--accent3);
    color: var(--accent3);
    background: rgba(123,47,255,0.05);
  }
  .btn-purple:hover { background: rgba(123,47,255,0.15); }

  .btn:disabled { opacity: 0.3; cursor: not-allowed; }

  /* VIDEO SECTION */
  .video-section {
    background: var(--surface);
    border: 1px solid rgba(0,245,255,0.1);
    border-radius: 24px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .section-title {
    font-family: 'Orbitron', monospace;
    font-size: 0.7rem;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .url-row {
    display: flex;
    gap: 10px;
  }

  .url-input {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(0,245,255,0.2);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    direction: ltr;
  }

  .url-input:focus { border-color: var(--accent); }
  .url-input::placeholder { color: var(--muted); }

  /* VIDEO PLAYER */
  .player-wrapper {
    margin-top: 20px;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    position: relative;
    display: none;
  }

  .player-wrapper.visible { display: block; }

  .player-wrapper iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border: none;
    display: block;
  }

  /* CLIENTS LIST */
  .clients-section {
    background: var(--surface);
    border: 1px solid rgba(0,245,255,0.1);
    border-radius: 24px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 10px;
    margin-top: 15px;
  }

  .client-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
    font-size: 0.8rem;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .client-card.connected { border-color: rgba(0,245,255,0.25); }
  .client-card.connected::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
  }

  .client-icon { font-size: 1.5rem; margin-bottom: 6px; }
  .client-name { color: var(--text); font-weight: 700; }
  .client-status { color: var(--muted); font-size: 0.7rem; margin-top: 3px; }

  /* ROOM LINK */
  .room-card {
    background: var(--surface);
    border: 1px solid rgba(123,47,255,0.2);
    border-radius: 24px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .room-link-box {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(123,47,255,0.08);
    border: 1px solid rgba(123,47,255,0.2);
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 15px;
    direction: ltr;
    word-break: break-all;
    font-size: 0.8rem;
    color: var(--accent3);
    font-family: monospace;
    cursor: pointer;
    transition: all 0.2s;
  }
  .room-link-box:hover { background: rgba(123,47,255,0.15); }

  .copy-hint { color: var(--muted); font-size: 0.75rem; margin-top: 8px; text-align: center; }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--accent);
    color: #000;
    font-weight: 700;
    padding: 12px 28px;
    border-radius: 100px;
    font-size: 0.9rem;
    z-index: 999;
    transition: transform 0.3s ease;
    pointer-events: none;
  }

  .toast.show { transform: translateX(-50%) translateY(0); }

  /* COUNTDOWN OVERLAY */
  .countdown-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5,8,16,0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    display: none;
  }

  .countdown-overlay.active { display: flex; }

  .countdown-num {
    font-family: 'Orbitron', monospace;
    font-size: 20vw;
    font-weight: 900;
    color: var(--accent);
    text-shadow: var(--glow);
    animation: pop 0.5s ease;
  }

  @keyframes pop {
    0% { transform: scale(1.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* VIEWER MODE */
  .viewer-video {
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .viewer-video iframe { width: 100%; height: 100%; border: none; }

  /* SETUP SCREEN */
  .setup-screen {
    text-align: center;
    padding: 40px 20px;
  }

  .setup-title {
    font-family: 'Orbitron', monospace;
    font-size: 1.2rem;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .setup-desc {
    color: var(--muted);
    margin-bottom: 40px;
    line-height: 1.8;
  }

  .role-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 500px;
    margin: 0 auto;
  }

  .role-card {
    background: var(--surface);
    border: 2px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 30px 20px;
    cursor: pointer;
    transition: all 0.3s;
    text-align: center;
  }

  .role-card:hover { border-color: var(--accent); box-shadow: var(--glow); transform: translateY(-3px); }
  .role-card:nth-child(2):hover { border-color: var(--accent3); box-shadow: 0 0 20px rgba(123,47,255,0.4); }

  .role-icon { font-size: 2.5rem; margin-bottom: 12px; }
  .role-title { font-weight: 700; font-size: 1rem; margin-bottom: 6px; }
  .role-desc { color: var(--muted); font-size: 0.8rem; line-height: 1.5; }

  /* RESPONSIVE */
  @media(max-width: 500px) {
    .role-cards { grid-template-columns: 1fr; }
    .controls-card { padding: 25px 15px; }
    .status-bar { gap: 15px; }
  }
</style>
</head>
<body>

<div class="container">
  <header>
    <div class="logo">VR SYNC</div>
    <div class="subtitle">تحكم في 20 جهاز في وقت واحد</div>
  </header>

  <!-- SETUP SCREEN -->
  <div id="setupScreen" class="setup-screen">
    <div class="setup-title">اختار دورك</div>
    <p class="setup-desc">
      المضيف يتحكم في التشغيل والإيقاف<br>
      المشاهدون بيشوفوا الفيديو ويستقبلوا الأوامر
    </p>
    <div class="role-cards">
      <div class="role-card" onclick="setRole('host')">
        <div class="role-icon">🎮</div>
        <div class="role-title">المضيف</div>
        <div class="role-desc">بتتحكم في الكل وبتشغّل الفيديو</div>
      </div>
      <div class="role-card" onclick="promptJoinRoom()">
        <div class="role-icon">🥽</div>
        <div class="role-title">مشاهد</div>
        <div class="role-desc">بتدخل الـ Room وبتشوف الفيديو</div>
      </div>
    </div>
  </div>

  <!-- HOST UI -->
  <div id="hostUI" style="display:none">

    <div class="status-bar">
      <div class="stat">
        <div class="stat-value" id="connectedCount">0</div>
        <div class="stat-label">متصل</div>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <div id="playStatus" class="conn-status">
          <div class="dot waiting"></div>
          <span>واقف</span>
        </div>
        <div class="stat-label">حالة الفيديو</div>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <div class="stat-value" id="timeDisplay" style="font-size:1.2rem">00:00</div>
        <div class="stat-label">الوقت</div>
      </div>
    </div>

    <!-- VIDEO INPUT -->
    <div class="video-section">
      <div class="section-title">🎬 رابط الفيديو</div>
      <div class="url-row">
        <input type="text" class="url-input" id="videoUrl" placeholder="https://youtube.com/watch?v=..." />
        <button class="btn btn-cyan" onclick="loadVideo()">تحميل</button>
      </div>
      <div class="player-wrapper" id="playerWrapper">
        <iframe id="ytPlayer" allow="autoplay" allowfullscreen></iframe>
      </div>
    </div>

    <!-- MAIN CONTROLS -->
    <div class="controls-card">
      <div class="role-badge host">🎮 أنت المضيف</div>

      <button class="play-btn" id="playBtn" onclick="togglePlay()">▶</button>

      <div class="btn-row">
        <button class="btn btn-cyan" onclick="syncAll()">🔄 مزامنة الكل</button>
        <button class="btn btn-red" onclick="stopAll()">⏹ إيقاف تام</button>
        <button class="btn btn-purple" onclick="countdownPlay()">⏱ عدّ تنازلي</button>
      </div>
    </div>

    <!-- CLIENTS -->
    <div class="clients-section">
      <div class="section-title">🥽 الأجهزة المتصلة</div>
      <div class="clients-grid" id="clientsGrid">
        <div style="color:var(--muted); font-size:0.85rem; grid-column:1/-1; text-align:center; padding:20px">
          في انتظار الأجهزة...
        </div>
      </div>
    </div>

    <!-- ROOM LINK -->
    <div class="room-card">
      <div class="section-title">🔗 رابط الـ Room</div>
      <p style="color:var(--muted); font-size:0.85rem; margin-bottom:5px">ابعت الرابط ده لكل الـ 20 جهاز يفتحوه</p>
      <div class="room-link-box" onclick="copyRoomLink()" id="roomLinkBox">جاري التوليد...</div>
      <div class="copy-hint">اضغط على الرابط للنسخ 📋</div>
    </div>

  </div>

  <!-- VIEWER UI -->
  <div id="viewerUI" style="display:none">
    <div class="status-bar" style="margin-bottom:20px">
      <div class="stat">
        <div id="viewerStatus" class="conn-status">
          <div class="dot waiting"></div>
          <span>جاري الاتصال...</span>
        </div>
        <div class="stat-label">الاتصال</div>
      </div>
      <div class="divider"></div>
      <div class="stat">
        <div class="stat-value" id="viewerTime" style="font-size:1.2rem">00:00</div>
        <div class="stat-label">الوقت</div>
      </div>
    </div>

    <div class="viewer-video">
      <iframe id="viewerPlayer" allow="autoplay" allowfullscreen></iframe>
    </div>

    <div style="text-align:center; color:var(--muted); font-size:0.85rem">
      🥽 في انتظار أوامر المضيف...
    </div>
  </div>
</div>

<!-- COUNTDOWN OVERLAY -->
<div class="countdown-overlay" id="countdownOverlay">
  <div class="countdown-num" id="countdownNum">3</div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ===================== CORE SYNC ENGINE =====================
// Uses BroadcastChannel for same-device tabs + localStorage events for cross-device

const ROOM_KEY_PREFIX = 'vrSync_';
let role = null;
let roomId = null;
let isPlaying = false;
let startTime = 0;
let videoId = null;
let clients = {};
let myId = 'device_' + Math.random().toString(36).substr(2, 6);
let timerInterval = null;
let bc = null;

// ===================== SETUP =====================

function setRole(r) {
  role = r;
  roomId = 'room_' + Math.random().toString(36).substr(2, 8);
  initRoom();
}

function promptJoinRoom() {
  const id = prompt('أدخل الـ Room ID اللي بعته المضيف:');
  if (!id) return;
  role = 'viewer';
  roomId = id.trim();
  initRoom();
}

function initRoom() {
  document.getElementById('setupScreen').style.display = 'none';

  // BroadcastChannel (same browser)
  try {
    bc = new BroadcastChannel(ROOM_KEY_PREFIX + roomId);
    bc.onmessage = (e) => handleMessage(e.data);
  } catch(e) {}

  // localStorage polling (cross-device on same network via shared storage - fallback)
  // Main cross-device method: we use a simple polling loop on localStorage key
  window.addEventListener('storage', (e) => {
    if (e.key === ROOM_KEY_PREFIX + roomId + '_cmd') {
      try { handleMessage(JSON.parse(e.newValue)); } catch(err) {}
    }
  });

  if (role === 'host') {
    document.getElementById('hostUI').style.display = 'block';
    document.getElementById('roomLinkBox').textContent = generateRoomUrl();
    // announce host
    broadcastMessage({ type: 'host_online', roomId });
    // heartbeat
    setInterval(sendHeartbeat, 2000);
    setInterval(updateTimer, 500);
  } else {
    document.getElementById('viewerUI').style.display = 'block';
    // register
    broadcastMessage({ type: 'viewer_join', id: myId, roomId });
    setInterval(() => broadcastMessage({ type: 'viewer_heartbeat', id: myId }), 2000);
    setInterval(updateViewerTimer, 500);
  }
}

function generateRoomUrl() {
  const url = window.location.href.split('?')[0];
  return url + '?room=' + roomId;
}

// ===================== MESSAGING =====================

function broadcastMessage(msg) {
  // BroadcastChannel
  if (bc) try { bc.postMessage(msg); } catch(e) {}

  // localStorage for cross-tab/device
  const key = ROOM_KEY_PREFIX + roomId + '_cmd';
  try {
    localStorage.setItem(key, JSON.stringify({ ...msg, _ts: Date.now() }));
  } catch(e) {}
}

function handleMessage(msg) {
  if (!msg || msg.roomId && msg.roomId !== roomId) return;

  if (role === 'host') {
    if (msg.type === 'viewer_join' || msg.type === 'viewer_heartbeat') {
      registerClient(msg.id);
    }
  }

  if (role === 'viewer') {
    if (msg.type === 'play') {
      startTime = msg.startTime;
      videoId = msg.videoId;
      loadViewerVideo(videoId);
      schedulePlay(msg.startTime);
    }
    if (msg.type === 'pause') {
      pauseViewerVideo();
    }
    if (msg.type === 'stop') {
      stopViewerVideo();
    }
    if (msg.type === 'sync') {
      startTime = msg.startTime;
      videoId = msg.videoId;
      loadViewerVideo(videoId);
      schedulePlay(msg.startTime);
    }
    if (msg.type === 'host_online') {
      document.getElementById('viewerStatus').innerHTML = '<div class="dot"></div><span>متصل ✓</span>';
    }
  }
}

// ===================== HOST FUNCTIONS =====================

function loadVideo() {
  const url = document.getElementById('videoUrl').value.trim();
  const id = extractYouTubeId(url);
  if (!id) { showToast('رابط غلط!'); return; }
  videoId = id;
  const wrapper = document.getElementById('playerWrapper');
  wrapper.classList.add('visible');
  document.getElementById('ytPlayer').src = `https://www.youtube.com/embed/${id}?enablejsapi=1&controls=1`;
  showToast('تم تحميل الفيديو ✓');
}

function togglePlay() {
  if (!videoId) { showToast('حمّل الفيديو الأول!'); return; }
  isPlaying ? 
